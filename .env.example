# ════════════════════════════════════════════════════════════
#  «Гадание от Лизы» — переменные окружения
#  Скопируй в .env и заполни своими значениями
# ════════════════════════════════════════════════════════════

# ── Бренд «Лизы» ────────────────────────────────────────────
# Как представляться
LIZA_NAME="Лиза"
# Тон общения: warm (тёплый) / mystic (мистический) / friendly (дружеский)
LIZA_TONE="warm"
# Обращение: ты / вы
LIZA_ADDRESS="ты"

# ── Telegram: бот ───────────────────────────────────────────
# Токен от @BotFather
BOT_TOKEN=""
# @username бота (для кнопок и WebApp)
LIZA_BOT_USERNAME="liza_taro_bot"

# ── Telegram: канал для подписки (ВОРОНКА) ──────────────────
# @username канала, на который подписываем (без @)
CHANNEL_USERNAME="liza_taro"
# Числовой ID канала для getChatMember (например -1001234567890)
# Узнать: перешли сообщение канала боту @userinfobot
CHANNEL_ID="-1000000000000"

# ── База данных ─────────────────────────────────────────────
# Локально (SQLite для разработки):
DATABASE_URL="file:./dev.db"
# PostgreSQL на Railway/Render:
# DATABASE_URL="postgresql://user:pass@host:5432/dbname"

# ── Нейросеть ───────────────────────────────────────────────
# Провайдер: mock (без ключа, шаблоны) / openai / openrouter / claude
AI_PROVIDER="mock"
AI_API_KEY=""
# Модель (зависит от провайдера)
AI_MODEL="gpt-4o-mini"
# Базовый URL (для OpenRouter или прокси)
# AI_BASE_URL="https://openrouter.ai/api/v1"

# ── Приложение ──────────────────────────────────────────────
# URL где крутится приложение (для webhook бота)
APP_URL="http://localhost:3000"
# Кол-во бесплатных раскладов без подписки
FREE_READS_DEFAULT="1"
# Секрет для подписи webhook'а (любая случайная строка)
WEBHOOK_SECRET="change-me-to-random-string"
